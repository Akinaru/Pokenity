generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid()) @db.Char(36)
  username       String          @unique @db.VarChar(50)
  email          String          @unique @db.VarChar(191)
  passwordHash   String          @map("password_hash") @db.VarChar(255)
  xp             Int             @default(0)
  characterId    String?         @map("character_id") @db.Char(36)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  inventory      InventoryItem[]
  boxOpenings    BoxOpening[]
  proposedTrades Trade[]         @relation("TradeProposer")
  receivedTrades Trade[]         @relation("TradeRecipient")
  character      Character?      @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([characterId])
  @@map("users")
}

enum DropResourceType {
  POKEMON
  ITEM
  MACHINE
}

model Box {
  id            String       @id @default(uuid()) @db.Char(36)
  name          String       @db.VarChar(100)
  pokeballImage String       @map("pokeball_image") @db.VarChar(512)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  entries       BoxEntry[]
  openings      BoxOpening[]

  @@map("boxes")
}

model BoxEntry {
  id           String           @id @default(uuid()) @db.Char(36)
  boxId        String           @map("box_id") @db.Char(36)
  resourceType DropResourceType @map("resource_type")
  resourceId   Int              @map("resource_id")
  resourceName String           @map("resource_name") @db.VarChar(120)
  dropRate     Float            @map("drop_rate")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  box          Box              @relation(fields: [boxId], references: [id], onDelete: Cascade)

  @@unique([boxId, resourceType, resourceId])
  @@map("box_entries")
}

model InventoryItem {
  id              String           @id @default(uuid()) @db.Char(36)
  userId          String           @map("user_id") @db.Char(36)
  resourceType    DropResourceType @map("resource_type")
  resourceId      Int              @map("resource_id")
  resourceName    String           @map("resource_name") @db.VarChar(120)
  isShiny         Boolean          @default(false) @map("is_shiny")
  quantity        Int              @default(1)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  firstObtainedAt DateTime         @default(now()) @map("first_obtained_at")
  lastObtainedAt  DateTime         @default(now()) @map("last_obtained_at")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceType, resourceId, isShiny])
  @@map("inventory_items")
}

model Character {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.VarChar(100)
  avatarUrl String   @map("avatar_url") @db.VarChar(512)
  imageUrl  String   @map("image_url") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]

  @@map("characters")
}

model BoxOpening {
  id               String           @id @default(uuid()) @db.Char(36)
  userId           String           @map("user_id") @db.Char(36)
  boxId            String?          @map("box_id") @db.Char(36)
  boxName          String           @map("box_name") @db.VarChar(100)
  boxPokeballImage String           @map("box_pokeball_image") @db.VarChar(512)
  resourceType     DropResourceType @map("resource_type")
  resourceId       Int              @map("resource_id")
  resourceName     String           @map("resource_name") @db.VarChar(120)
  isShiny          Boolean          @default(false) @map("is_shiny")
  dropRate         Float            @map("drop_rate")
  details          Json?            @db.Json
  openedAt         DateTime         @default(now()) @map("opened_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  box              Box?             @relation(fields: [boxId], references: [id], onDelete: SetNull)

  @@index([userId, openedAt])
  @@index([boxId])
  @@map("box_openings")
}

enum TradeStatus {
  PENDING
  WAITING_CONFIRMATION
  COMPLETED
  CANCELED
  DECLINED
}

model Trade {
  id                   String               @id @default(uuid()) @db.Char(36)
  proposerId           String               @map("proposer_id") @db.Char(36)
  recipientId          String?              @map("recipient_id") @db.Char(36)
  status               TradeStatus          @default(PENDING)
  offeredResourceType  DropResourceType     @map("offered_resource_type")
  offeredResourceId    Int                  @map("offered_resource_id")
  offeredResourceName  String               @map("offered_resource_name") @db.VarChar(120)
  offeredIsShiny       Boolean              @default(false) @map("offered_is_shiny")
  receivedResourceType DropResourceType?    @map("received_resource_type")
  receivedResourceId   Int?                 @map("received_resource_id")
  receivedResourceName String?              @map("received_resource_name") @db.VarChar(120)
  receivedIsShiny      Boolean?             @map("received_is_shiny")
  acceptedAt           DateTime?            @map("accepted_at")
  confirmedAt          DateTime?            @map("confirmed_at")
  completedAt          DateTime?            @map("completed_at")
  canceledAt           DateTime?            @map("canceled_at")
  declinedAt           DateTime?            @map("declined_at")
  expiresAt            DateTime?            @map("expires_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  proposer             User                 @relation("TradeProposer", fields: [proposerId], references: [id], onDelete: Cascade)
  recipient            User?                @relation("TradeRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  offeredItems         TradeOfferedItem[]
  requestedItems       TradeRequestedItem[]

  @@index([proposerId, status])
  @@index([recipientId, status])
  @@map("trades")
}

model TradeRequestedItem {
  id           String           @id @default(uuid()) @db.Char(36)
  tradeId      String           @map("trade_id") @db.Char(36)
  resourceType DropResourceType @default(POKEMON) @map("resource_type")
  resourceId   Int              @map("resource_id")
  resourceName String           @map("resource_name") @db.VarChar(120)
  isShiny      Boolean          @default(false) @map("is_shiny")
  quantity     Int              @default(1)
  createdAt    DateTime         @default(now()) @map("created_at")
  trade        Trade            @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@map("trade_requested_items")
}

model TradeOfferedItem {
  id           String           @id @default(uuid()) @db.Char(36)
  tradeId      String           @map("trade_id") @db.Char(36)
  resourceType DropResourceType @default(POKEMON) @map("resource_type")
  resourceId   Int              @map("resource_id")
  resourceName String           @map("resource_name") @db.VarChar(120)
  isShiny      Boolean          @default(false) @map("is_shiny")
  quantity     Int              @default(1)
  createdAt    DateTime         @default(now()) @map("created_at")
  trade        Trade            @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@map("trade_offered_items")
}
